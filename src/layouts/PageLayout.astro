---
import Navigation from "components/Navigation.astro";
import NavigationItem from "components/NavigationItem.astro";

import Button from "components/Button.svelte";
import { GITHUB_REPO_URL, DISCORD_INVITE_URL } from "config";
import BaseLayout, { type Banner } from "./BaseLayout.astro";

interface Props {
	name?: string;
	title?: string;
	type?: string;
	description?: string;
	banner?: Banner;
}

const {
	name = "Davis High Robotics",
	title = "Davis High Robotics",
	description = "Davis High Robotics Academiac",
	banner = {
		url: "/images/Davis_logo.jpg",
		width: 280,
		height: 280,
		alt: "davis logo",
		twitter_card: "summary",
	},
} = Astro.props;
---

<BaseLayout {name} {title} {description} {banner}>
	<Button class="skip-to-content" href="#content">Skip to content</Button>
	<Navigation title="DHS ROBOTICS">
		<img
			slot="logo"
			width="36"
			height="36"
			src="/images/Davis_logo.jpg"
			alt="Davis Logo"
		/>
		<NavigationItem href="/docs2/">Learn</NavigationItem>
		<NavigationItem href="/programming/">Programming</NavigationItem>

		<!-- <NavigationItem href="https://docs.rs/vexide/" external>API</NavigationItem> -->
		<NavigationItem href="/releases/">Releases</NavigationItem>
		<NavigationItem href="/blog/">Blog</NavigationItem>
		<Fragment slot="actions">
			<Button
				variant="outlined"
				href={DISCORD_INVITE_URL}
				target="_blank"
				rel="noreferrer noopener"
			>
				Discord
			</Button>
			<Button
				variant="outlined"
				href={GITHUB_REPO_URL}
				target="_blank"
				rel="noreferrer noopener"
			>
				GitHub
			</Button>
		</Fragment>
	</Navigation>
	<slot />
</BaseLayout>
