---
import Navigation from "components/Navigation.astro";
import NavigationItem from "components/NavigationItem.astro";

import Button from "components/Button.svelte";
import DocsSearch from "components/DocsSearch.svelte";
import MarkdownStyles from "components/MarkdownStyles.astro";
import { GITHUB_ORG_URL, LEARN_SIDEBAR } from "config";
import BaseLayout from "./BaseLayout.astro";
import { getEntry, getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;

const { page: currentPage } = Astro.props;

const all = await getCollection("learn");
console.log(all.map(p => p.slug));

type SidebarEntry = string | { title: string; children: string[] };

function flattenEntries(entries: SidebarEntry[]): string[] {
  return entries.flatMap(e => typeof e === "string" ? [e] : e.children);
}

const allPages = Object.values(LEARN_SIDEBAR).flatMap(flattenEntries);
const currentCategory = (Object.entries(LEARN_SIDEBAR).find(([, entries]) =>
  flattenEntries(entries as SidebarEntry[]).includes(currentPage.slug)
) ?? ["Unknown"])[0];

console.log("currentPage.slug:", currentPage.slug);
console.log("allPages:", allPages);

const index = allPages.indexOf(currentPage.slug);
const prevPageId = allPages[index - 1];
const nextPageId = allPages[index + 1];

const [prevPage, nextPage] = await Promise.all([
  prevPageId ? getEntry("learn", prevPageId) : undefined,
  nextPageId ? getEntry("learn", nextPageId) : undefined,
]);
---

<script>
    document.addEventListener("astro:page-load", () => {
        const sidebar = document.querySelector(".docs-sidebar")!;
        const storedState = sessionStorage.getItem("docsSidebarScrollPosition");

        if (storedState) {
            sidebar.scrollTop = parseInt(storedState);
        }

        sidebar.addEventListener("scroll", () => {
            sessionStorage.setItem(
                "docsSidebarScrollPosition",
                sidebar.scrollTop.toString(),
            );
        });
    });
</script>

<BaseLayout
    name="Learn"
    title={currentPage.data.title}
    description="Documentation and tutorials."
    banner={{
        url: `${base}images/Davis_logo.png`,
        width: 280,
        height: 280,
        alt: "davis logo",
        twitter_card: "summary",
    }}
>
    <Button class="skip-to-content" href="#content">Skip to content</Button>
    <Navigation title="DHRA">
        <img
            slot="logo"
            width="36"
            height="36"
            src={`${base}images/Davis_logo.jpg`}
            alt="Davis logo"
        />
        <span slot="title" class="navigation-docs-chip">Docs</span>
        <NavigationItem selected href={`${base}learn/`}>General Documentation</NavigationItem>
        <NavigationItem href={`${base}programming/`}>Programming Documentation</NavigationItem>
        <DocsSearch slot="right" client:load />
        <Fragment slot="mobile">
            {Object.entries(LEARN_SIDEBAR).map(([category, entries]) => (
                <>
                    <strong class="docs-category-label">{category}</strong>
                    <ul class="docs-category">
                        {(entries as SidebarEntry[]).map(async (entry) => {
                            if (typeof entry === "string") {
                                const page = await getEntry("learn", entry)!;
                                return !page.data.draft && (
                                    <li class:list={["docs-sidebar-item", { selected: page.slug === currentPage.slug }]}>
                                        <a href={page.slug === "index" ? `${base}learn/` : `${base}learn/${page.slug}/`}>
                                            {page.data.title}
                                        </a>
                                    </li>
                                );
                            } else {
                                return (
                                    <li class="docs-sidebar-group">
                                        <span class="docs-sidebar-group-label">{entry.title}</span>
                                        <ul class="docs-sidebar-group-children">
                                            {entry.children.map(async (childEntry) => {
                                                const page = await getEntry("learn", childEntry)!;
                                                return !page.data.draft && (
                                                    <li class:list={["docs-sidebar-item", { selected: page.slug === currentPage.slug }]}>
                                                        <a href={`${base}learn/${page.slug}/`}>
                                                            {page.data.title}
                                                        </a>
                                                    </li>
                                                );
                                            })}
                                        </ul>
                                    </li>
                                );
                            }
                        })}
                    </ul>
                </>
            ))}
        </Fragment>
    </Navigation>
    <main class="docs-layout">
        <aside class="docs-sidebar">
            {Object.entries(LEARN_SIDEBAR).map(([category, entries]) => (
                <>
                    <strong class="docs-category-label">{category}</strong>
                    <ul class="docs-category">
                        {(entries as SidebarEntry[]).map(async (entry) => {
                            if (typeof entry === "string") {
                                const page = await getEntry("learn", entry)!;
                                return !page.data.draft && (
                                    <li class:list={["docs-sidebar-item", { selected: page.slug === currentPage.slug }]}>
                                        <a href={page.slug === "index" ? `${base}learn/` : `${base}learn/${page.slug}/`}>
                                            {page.data.title}
                                        </a>
                                    </li>
                                );
                            } else {
                                return (
                                    <li class="docs-sidebar-group">
                                        <span class="docs-sidebar-group-label">{entry.title}</span>
                                        <ul class="docs-sidebar-group-children">
                                            {entry.children.map(async (childEntry) => {
                                                const page = await getEntry("learn", childEntry)!;
                                                return !page.data.draft && (
                                                    <li class:list={["docs-sidebar-item", { selected: page.slug === currentPage.slug }]}>
                                                        <a href={`${base}learn/${page.slug}/`}>
                                                            {page.data.title}
                                                        </a>
                                                    </li>
                                                );
                                            })}
                                        </ul>
                                    </li>
                                );
                            }
                        })}
                    </ul>
                </>
            ))}
        </aside>
        <div class="docs-page">
            <header class="docs-header">
                <div class="docs-header-inner">
                    <span class="docs-breadcrumbs">{currentCategory} > {currentPage.data.title}</span>
                    <h1>{currentPage.data.title}</h1>
                    <Button
                        class="edit-on-github"
                        href={`${GITHUB_ORG_URL}/website/tree/main/src/content/learn/${currentPage.id}`}
                    >
                        Edit This Page
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 32 32">
                            <path fill="currentColor" d="M10 6v2h12.59L6 24.59L7.41 26L24 9.41V22h2V6z"></path>
                        </svg>
                    </Button>
                    {currentPage.data.links && (
                        <div class="docs-header-links">
                            {Object.entries(currentPage.data.links).map(([name, href]) => (
                                <a href={href as string} target="_blank" rel="noreferrer noopener">
                                    {name}
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 32 32">
                                        <path fill="currentColor" d="M10 6v2h12.59L6 24.59L7.41 26L24 9.41V22h2V6z" />
                                    </svg>
                                </a>
                            ))}
                        </div>
                    )}
                </div>
            </header>

            <MarkdownStyles element="article" id="content">
                <span class="desc-text"><span class="desc-text-strong">Description:</span> {currentPage.data.description}</span>
                <hr />
                <slot />
                {prevPage ? (
    
                class="page-action prev-page"
                href={prevPage.slug === "index" ? `${base}learn/` : `${base}learn/${prevPage.slug}/`}
            >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24">
                    <path d="M15.28 5.22a.75.75 0 0 1 0 1.06L9.56 12l5.72 5.72a.749.749 0 0 1-.326 1.275.749.749 0 0 1-.734-.215l-6.25-6.25a.75.75 0 0 1 0-1.06l6.25-6.25a.75.75 0 0 1 1.06 0Z" />
                </svg>
                <div class="page-action-contents">
                    Previous
                    <strong>{prevPage.data.title}</strong>
                </div>
            </a>
            ) : (
                <div />
            )}
            {nextPage ? (
                
                    class="page-action next-page"
                    href={nextPage.slug === "index" ? `${base}learn/` : `${base}learn/${nextPage.slug}/`}
                >
                    <div class="page-action-contents">
                        Next
                        <strong>{nextPage.data.title}</strong>
                    </div>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24">
                        <path d="M8.72 18.78a.75.75 0 0 1 0-1.06L14.44 12 8.72 6.28a.751.751 0 0 1 .018-1.042.751.751 0 0 1 1.042-.018l6.25 6.25a.75.75 0 0 1 0 1.06l-6.25 6.25a.75.75 0 0 1-1.06 0Z" />
                    </svg>
                </a>
            ) : (
                <div />
            )}
                    </nav>
                )}
            </MarkdownStyles>
        </div>
    </main>
</BaseLayout>